# Yandex Weather — бесплатный тариф «Погода на вашем сайте»
# Ключ: https://developer.tech.yandex.ru/ → сервис «Погода»
# Лимит: 50 запросов/сутки на ключ (достаточно с кэшем 1 ч)

# Скопируйте в .env и вставьте реальный ключ:
YANDEX_WEATHER_KEY=your_api_key_here

# Прокси с серверным кэшем (рекомендуется, ключ не попадает в бандл)
# Dev/preview: встроен в Vite (vite-plugins/weatherProxy.js)
# Prod: node scripts/weather-proxy.mjs + nginx proxy_pass
VITE_WEATHER_PROXY=/api/weather

# Продакшн: виджет в статической сборке (если прокси на сервере, но ключ не в build-env):
# VITE_WEATHER_ENABLED=true

# Прямые запросы из браузера (не рекомендуется — сжигает лимит 50/день):
# VITE_WEATHER_DIRECT=true
# VITE_YANDEX_WEATHER_KEY=your_api_key_here

# Отключить виджет погоды:
# VITE_WEATHER_DISABLED=true